{
  "name": "react-synth-plus",
  "version": "1.0.2",
  "description": "A high-performance, headless wavetable synthesizer for React built on Tone.js",
  "author": "Ashraff Hathibelagal",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/react-synth-plus.umd.js",
  "module": "./dist/react-synth-plus.es.js",
  "unpkg": "./dist/react-synth-plus.umd.js",
  "jsdelivr": "./dist/react-synth-plus.umd.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/react-synth-plus.es.js",
      "require": "./dist/react-synth-plus.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:showcase": "VITE_SHOWCASE=true vite",
    "build": "vite build",
    "build:lib": "vite build --mode library",
    "preview": "vite preview",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tone": ">=14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.1.2",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.27",
    "jsdom": "^22.1.0",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.1",
    "tone": "^14.8.49",
    "vite": "^4.4.5",
    "vitest": "^0.34.2"
  }
}
